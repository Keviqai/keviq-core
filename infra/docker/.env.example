# Keviq Core — Environment Configuration
#
# Copy this file to .env.local before running:
#   cp .env.example .env.local
#
# For production, change ALL values marked "CHANGE IN PRODUCTION".
# See docs/ops/production-deployment-checklist.md for full guidance.

# ── Infrastructure ───────────────────────────────────────────────
POSTGRES_USER=superuser
POSTGRES_PASSWORD=superpassword
POSTGRES_DB=mona_os
REDIS_PASSWORD=dev-redis-password

# ── Secrets (CHANGE IN PRODUCTION) ──────────────────────────────
AUTH_JWT_SECRET=dev-secret-change-in-production
INTERNAL_AUTH_SECRET=dev-internal-auth-secret-change-in-production

# ── Frontend ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
