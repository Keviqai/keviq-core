# Cloud-like environment — used with docker-compose.cloud.yml
#
# All values MUST be provided. No dev defaults.
#
# Usage:
#   cp .env.cloud.example .env.cloud
#   # Fill in all values
#   docker compose -f docker-compose.yml -f docker-compose.cloud.yml \
#     --env-file .env.cloud up

# ── Infrastructure ───────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=mona_os
REDIS_PASSWORD=

# ── Database URLs (one per service schema) ───────────────────────
AUTH_DB_URL=postgresql://auth_user:PASSWORD@HOST/mona_os
POLICY_DB_URL=postgresql://policy_user:PASSWORD@HOST/mona_os
ORCHESTRATOR_DB_URL=postgresql://orchestrator_user:PASSWORD@HOST/mona_os
AGENT_RUNTIME_DB_URL=postgresql://agent_runtime_user:PASSWORD@HOST/mona_os
ARTIFACT_DB_URL=postgresql://artifact_user:PASSWORD@HOST/mona_os
EXECUTION_DB_URL=postgresql://execution_user:PASSWORD@HOST/mona_os
WORKSPACE_DB_URL=postgresql://workspace_user:PASSWORD@HOST/mona_os
SECRET_DB_URL=postgresql://secret_user:PASSWORD@HOST/mona_os
MODEL_GW_DB_URL=postgresql://model_gw_user:PASSWORD@HOST/mona_os
AUDIT_DB_URL=postgresql://audit_user:PASSWORD@HOST/mona_os
EVENT_STORE_DB_URL=postgresql://event_store_user:PASSWORD@HOST/mona_os
NOTIFICATION_DB_URL=postgresql://notification_user:PASSWORD@HOST/mona_os

# ── Event Bus ────────────────────────────────────────────────────
EVENT_BUS_URL=redis://:PASSWORD@HOST:6379

# ── Secrets ──────────────────────────────────────────────────────
AUTH_JWT_SECRET=
INTERNAL_AUTH_SECRET=
CORS_ALLOWED_ORIGINS=https://app.example.com

# ── Execution Backend ───────────────────────────────────────────
# Options: docker-local, noop, k8s-job
EXECUTION_BACKEND=noop

# ── Artifact Storage ────────────────────────────────────────────
# Options: local, s3
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_STORAGE_PATH=/data/artifacts
# For S3 backend:
# ARTIFACT_S3_BUCKET=my-artifacts-bucket
# ARTIFACT_S3_REGION=us-east-1

# ── Service Discovery (override only if services are external) ──
# AUTH_SERVICE_URL=http://auth-service:8000
# WORKSPACE_SERVICE_URL=http://workspace-service:8000
# POLICY_SERVICE_URL=http://policy-service:8000
# ORCHESTRATOR_URL=http://orchestrator:8000
# ARTIFACT_SERVICE_URL=http://artifact-service:8000
# EVENT_STORE_URL=http://event-store:8000
# MODEL_GATEWAY_URL=http://model-gateway:8000
# AGENT_RUNTIME_URL=http://agent-runtime:8000
# EXECUTION_SERVICE_URL=http://execution-service:8000
