{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "outDir": "dist",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@keviq/domain-types": ["../../packages/domain-types/src"],
      "@keviq/api-client": ["../../packages/api-client/src"],
      "@keviq/server-state": ["../../packages/server-state/src"],
      "@keviq/routing": ["../../packages/routing/src"],
      "@keviq/permissions": ["../../packages/permissions/src"],
      "@keviq/ui-state": ["../../packages/ui-state/src"],
      "@keviq/live-state": ["../../packages/live-state/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".next"]
}
